# OpenAI API Configuration (only needed if using LLM_PROVIDER=openai)
# Required: Your OpenAI API key for LLM-based answer generation
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# LLM Provider Configuration
# LLM_PROVIDER: Choose between "openai" (paid, requires API key) or "ollama" (free, local)
# Options: openai, ollama
LLM_PROVIDER=ollama

# Ollama Configuration (only needed if using LLM_PROVIDER=ollama)
# OLLAMA_BASE_URL: URL where Ollama is running (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Chunking Configuration
# CHUNK_SIZE: Size of text chunks in characters (default: 1000)
# Larger chunks provide more context but may reduce retrieval precision
CHUNK_SIZE=1000

# CHUNK_OVERLAP: Number of overlapping characters between consecutive chunks (default: 200)
# Overlap ensures context continuity across chunk boundaries
CHUNK_OVERLAP=200

# Retrieval Configuration
# TOP_K_CHUNKS: Number of most similar chunks to retrieve for each query (default: 5)
# More chunks provide more context but increase processing time
TOP_K_CHUNKS=5

# SIMILARITY_THRESHOLD: Minimum similarity score (0.0-1.0) for chunk retrieval (default: 0.3)
# Higher threshold means stricter relevance filtering
SIMILARITY_THRESHOLD=0.3

# Model Configuration
# EMBEDDING_MODEL: Sentence transformer model for generating embeddings (default: all-MiniLM-L6-v2)
# Options: all-MiniLM-L6-v2, all-mpnet-base-v2, multi-qa-mpnet-base-dot-v1
EMBEDDING_MODEL=all-MiniLM-L6-v2

# LLM_MODEL: OpenAI model for answer generation (default: gpt-3.5-turbo)
# For OpenAI: gpt-3.5-turbo, gpt-4, gpt-4-turbo
# For Ollama: llama3.2, mistral, phi3, gemma2
LLM_MODEL=llama3.2

# LLM_TEMPERATURE: Temperature for LLM generation (0.0-2.0, default: 0.0)
# 0.0 = deterministic, higher values = more creative but less consistent
LLM_TEMPERATURE=0.0

# Storage Paths
# VECTOR_INDEX_PATH: Path to save/load FAISS vector index (default: ./data/vector_index.faiss)
VECTOR_INDEX_PATH=./data/vector_index.faiss

# CHUNKS_METADATA_PATH: Path to save/load chunk metadata (default: ./data/chunks_metadata.json)
CHUNKS_METADATA_PATH=./data/chunks_metadata.json

